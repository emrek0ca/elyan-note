{
  "name": "elyan-note",
  "private": true,
  "version": "0.1.3",
  "description": "A sleek desktop note app built with Electron and vanilla JavaScript",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --publish never"
  },
  "dependencies": {
    "electron": "^41.1.0"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.emrek0ca.elyan-note",
    "productName": "Elyan Note",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs",
      "index.html",
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
